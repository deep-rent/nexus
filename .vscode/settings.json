{
  "editor.formatOnSave": true,
  "editor.formatOnType": true,
  "files.associations": {
    "LICENSE": "plaintext"
  },
  "files.encoding": "utf8",
  "[go]": {
    "editor.rulers": [
      80
    ],
    "editor.defaultFormatter": "golang.go",
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always"
    }
  },
  "[markdown]": {
    "editor.rulers": [
      100
    ]
  },
  "[plaintext]": {
    "editor.formatOnSave": false
  },
  "go.lintTool": "golangci-lint",
  "go.lintFlags": [
    "--path-mode=abs"
  ],
  "go.formatTool": "gofumpt",
  "go.alternateTools": {},
  "go.formatFlags": [],
  "go.toolsEnvVars": {
    "GOEXPERIMENT": "jsonv2"
  },
  "go.toolsManagement.autoUpdate": true,
  "search.exclude": {
    "**/coverage.out": true,
    "**/dist": true,
    "**/go.sum": true,
    "**/vendor": true
  }
}
